# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=notes
POSTGRES_PASSWORD=notes_secret
POSTGRES_DB=notes_sell
DATABASE_URL=postgresql://notes:notes_secret@localhost:5433/notes_sell

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=notes-chapters

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ── Razorpay (test mode — fill from Razorpay Dashboard > Settings > API Keys) ─
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Viewer session ────────────────────────────────────────────────────────────
VIEWER_SESSION_SECRET=another_long_random_secret_for_viewer_tokens
VIEWER_SESSION_TTL_MINUTES=10

# ── Rate limiting ─────────────────────────────────────────────────────────────
PAGE_FETCH_RATE_LIMIT=60
PAGE_FETCH_RATE_WINDOW_SECONDS=60
